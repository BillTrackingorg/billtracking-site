# Normalise line endings: LF in the repository, LF on checkout everywhere.
# Without this, Git on Windows checks out CRLF while storing LF, which produces
# whole-file diffs the moment anyone on another platform touches a file.
* text=auto eol=lf

# Binary — never touch these
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
